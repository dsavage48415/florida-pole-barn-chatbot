# Turso Database
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# OpenRouter AI
OPENROUTER_API_KEY=your-openrouter-api-key

# Firebase Storage (for keyframe images)
